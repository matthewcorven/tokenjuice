{
  "id": "devops/kubectl-logs",
  "family": "kubernetes-logs",
  "description": "Compact kubectl logs output while preserving key log lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["kubectl"],
    "argvIncludes": [["logs"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 20
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "warn",
      "flags": "i"
    }
  ]
}
