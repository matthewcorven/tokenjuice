{
  "id": "build/webpack",
  "family": "build-bundler",
  "description": "Compact webpack output while preserving module errors and warnings.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["webpack"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 18,
    "tail": 16
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "warning",
      "flags": "i"
    }
  ]
}
