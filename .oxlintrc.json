{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "vitest",
    "node"
  ],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist/**",
    "release/**"
  ],
  "rules": {
    "no-control-regex": "off",
    "preserve-caught-error": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/no-array-reverse": "off",
    "unicorn/no-array-sort": "off"
  },
  "env": {
    "builtin": true
  }
}
